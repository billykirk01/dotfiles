    "Scope": {
        "prefix": "Scope",
        "description": "",
        "body": [
            "$1MWP > MWC",
            "",
            "CHG - Title",
            "",
            "    Server - envs: ",
            "    etXXXX - ENV",
            "",
            "    Staged in:",
            "    Runbook"
        ]
