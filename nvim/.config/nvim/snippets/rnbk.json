    "Disk Expanison": {
        "prefix": "Disk Expanison",
        "description": "",
        "body": [
            "[] Move disk expansion CHG to implement",
            "",
            "[] Submit `Expand List of Disks by UUID` automation request in SN:",
            "{vm}",
            "{UUID},{size}",
            "",
            "[] As root (#) on {vm(s)}:",
            "# rescan-scsi-bus.sh --resize",
            "# lsscsi -is #confirm disk size changes (current show as ? GB)",
            "# for disk in $(pvs | grep {volume_group} | awk '{print \\$1}'); do pvresize \\$disk; done",
            "# pvs #confirm PV size changes",
            "# vgs #confirm free space in VG",
            "# lvresize -r -l +100%FREE /dev/mapper/{volume_group}-{logical_volume}",
            "",
            "[] Move disk expansion CHG to review and close if no issues"
        ]
    },
    "NP Patching - IRIS": {
        "prefix": "NP Patching - IRIS",
        "description": "",
        "body": [
            "[] Move puppet/patching CHG to implement.",
            "",
            "As epicadm (\\$) / root (#) on ?:",
            "    [] Disable redalert and bring environments to RL-D",
            "    \\$ /epic/redalert/bin/ra_sched --da 1h",
            "    \\$ for inst in \\$(iris qlist | cut -d^ -f2); do \\$inst/../bin/runlevel -r d & done; wait; /epic/bin/epiccontrol all",
            "",
            "    [] Run Puppet at RL-D ",
            "    # puppet agent -t --no-noop",
            "",
            "    [] Bring environments to RL-C",
            "    \\$ for inst in \\$(iris qlist | cut -d^ -f2); do \\$inst/../bin/runlevel -r c & done; wait; /epic/bin/epiccontrol all",
            "",
            "    [] Patch",
            "    # apt update",
            "    # apt dist-upgrade",
            "    # apt autoremove",
            "    # apt clean",
            "    # apt list --upgradeable #confirm nothing else to apply",
            "    # shutdown -r now",
            "",
            "    [] Post-reboot health checks",
            "    \\$ /epic/redalert/bin/ra_sched --ea",
            "    \\$ /epic/redalert/bin/ra_sched --status #`ra_sched --start` if not running, `ra_sched --ea` if alerting disabled.",
            "    \\$ /epic/redalert/bin/esmp --status #`esmp --start` if not running.",
            "    \\$ /epic/bin/epiccontrol all #expect all at RL-UA",
            "",
            "    [] Final puppet run",
            "    # puppet agent -t --no-noop",
            "",
            "[] Move puppet/patching CHG to review and close if no issues",
            "",
            "[] Move HRQ to closed complete"
        ]
    },
    "Bolt Patching": {
        "prefix": "Bolt Patching",
        "description": "",
        "body": [
            "[] Move puppet/patching CHG implement",
            "",
            "[] Download the json files attached to MWC and move it onto ehcr-lindev01",
            "",
            "As {user}-t1 (\\$) on ehcr-lindev01:",
            "    [] Setup bolt",
            "    \\$ puppet_utils token -f",
            "    \\$ puppet_utils bolt",
            "    \\$ bolt module install --no-resolve",
            "",
            "    [] Run the bolt plans",
            "    \\$ bolt plan run odba_maintenance --params @${3:et####_np_patching.json}",
            "",
            "[] Move puppet/patching CHG to review and close if no issues",
            "",
            "[] Move tencon HRQ to testing"
        ]
    },
    "Refresh - NP or TRN": {
        "prefix": "Refresh",
        "description": "",
        "body": [
            "[] Move refresh CHG to implement",
            "",
            "As epicadm (\\$) on ?:",
            "    [] Remove the break hook script",
            "    \\$ /epic/bin/configure",
            "        Environment Copy >> Scenarios >> ?",
            "            Edit Hooks",
            "                d. Delete hook ",
            "                    Hook script:  /bin/false \"prevent unplanned refreshes\"",
            "                    Stage to run: PREEXECUTION",
            "",
            "    [] Kick off the refresh ",
            "    \\$ /epic/bin/envcopy -s ?",
            "    ",
            "    [] Monitor the refresh",
            "    \\$ tail -f $(ls -tr /epic/logs/envcopy_?.log* | tail -n1)",
            "    ",
            "    [] post refresh health checks",
            "    \\$ /epic/redalert/bin/ra_sched --status #`ra_sched --start` if not running, `ra_sched --ea` if alerting disabled.",
            "    \\$ /epic/redalert/bin/esmp --status #`esmp --start` if not running.",
            "    \\$ /epic/bin/epiccontrol all #expect all at RL-UA",
            "    ",
            "    [] Add the hook script back in so this refresh doesn't get run accidentally",
            "    \\$ /epic/bin/configure",
            "        Environment Copy >> Scenarios >> ?",
            "            Edit Hooks",
            "                a. add hook ",
            "                    Hook script:  /bin/false \"prevent unplanned refreshes\"",
            "                    Stage to run: PREEXECUTION",
            "",
            "[] Move refresh CHG to review and close if no issues"
        ]
    },
    "Reinit - Full Size - GT.M": {
        "prefix": "Reinit - Full Size - GT.M",
        "description": "",
        "body": [
            "$1[] Move reinit CHG to implement",
            "",
            "As epicadm (\\$) / root (#) on {vm}:",
            "    [] Change the stage on the current break hook script from `PREEXECUTION` to `PRERUNTASK`",
            "    \\$ /epic/bin/configure",
            "        Environment Copy >> Scenarios >> {scenario} >> Edit Hooks",
            "",
            "    [] Save off a new environment creation EVT record from SUP to be used for the reinit",
            "    \\$ rm /epicfiles/nonprdfiles/install/envinit/zEnvCopy*",
            "    \\$ /epic/sup/bin/session --dir",
            "        d saveConfig^%ZeENV(\"/epicfiles/nonprdfiles/install/envinit/\",1,{evt_id})",
            "",
            "As epicadm (\\$) / root (#) on {vm}:",
            "    [] Submit the `Copy PRD to SUP or RPT` automation request to refresh {env} from PRD",
            "    Tenant ID: {####}",
            "    Datacenter: {v|r}",
            "    PRD environment: {blank}",
            "    Environment: {env}",
            "    PRD VM number: 01",
            "    VM number: 01",
            "",
            "    [] Monitor refresh log and wait for envcopy to fail at pre-runtasks",
            "    \\$ tail -f $(ls -tr /epic/logs/envcopy_{scenario}.log* | tail -n1)",
            "",
            "    [] Run recreate_environment from the PREINIT stage",
            "    # /usr/local/epic_hosting/ruby/bin/recreate_environment -t {env} --start_stage PREINIT",
            "    # /usr/local/epic_hosting/ruby/bin/recreate_environment -t {env} --start_stage PREINIT --no_dry_run",
            "",
            "    [] Configure event logging",
            "    d setup^EPMUTIL ",
            "        Event Logging Settings >> page down twice to `File Directories for this Environment`",
            "            Node Name: {env}",
            "            File Directory: /epicfiles/nonprdfiles/event_log/{env}",
            "    ",
            "    [] Restore non-prd cert paths for ECF/TLS",
            "    d ^%ZeUSTBL",
            "        Communication >> Security >> TLS Settings",
            "        Public certificate file: /epic/local/epic/nonprd/certs/ecf-tls-np.cer",
            "        Private key file: /epic/local/epic/nonprd/certs/private/ecf-tls-np.key",
            "",
            "    [] Reset envcopy and re-enable alerting",
            "    \\$ /epic/bin/envcopy --reset -s {scenario}",
            "    \\$ /epic/redalert/bin/ra_sched --ea",
            "",
            "    [] Change the stage on the current break hook script from `PRERUNTASK` to `PREEXECUTION`",
            "    \\$ /epic/bin/configure",
            "        Environment Copy >> Scenarios >> {scenario} >> Edit Hooks",
            "",
            "[] Move reinit CHG to review and close if no issues"
        ]
    },
    "Reinit - full size - IRIS": {
        "prefix": "Reinit - Full Size",
        "description": "",
        "body": [
            "[] Move reinit CHG to implement",
            "",
            "As epicadm (\\$) / root (#) on ?:",
            "    [] Change the stage on the current break hook script from `PREEXECUTION` to `PRERUNTASK`",
            "    \\$ /epic/bin/configure",
            "        Environment Copy >> Scenarios >> ? >> Edit Hooks",
            "",
            "    [] Save off a new environment creation EVT record from ? to be used for the reinit",
            "    \\$ rm /epicfiles/nonprdfiles/install/envinit/zEnvCopy*",
            "    \\$ iris session ? -U ?",
            "        d saveConfig^%ZeENV(\"/epicfiles/nonprdfiles/install/envinit/\",1,?)",
            "",
            "As epicadm (\\$) / root (#) on ?:",
            "    [] Submit the `Copy PRD to SUP or RPT` automation request to refresh ? from PRD",
            "    Tenant ID: et####",
            "    Datacenter: (v|r)",
            "    PRD environment: {blank}",
            "    Environment: ?",
            "    PRD VM number: 01",
            "    VM number: 01",
            "",
            "    [] Monitor refresh log and wait for envcopy to fail at pre-runtasks",
            "    \\$ tail -f $(ls -tr /epic/logs/envcopy_?.log* | tail -n1)",
            "",
            "    [] Run recreate_environment from the PREINIT stage",
            "    # /usr/local/epic_hosting/ruby/bin/recreate_environment -t ? --start_stage PREINIT",
            "    # /usr/local/epic_hosting/ruby/bin/recreate_environment -t ? --start_stage PREINIT --no_dry_run",
            "",
            "    [] Configure event logging",
            "    d setup^EPMUTIL ",
            "        Event Logging Settings >> page down twice to `File Directories for this Environment`",
            "            Node Name: ?",
            "            File Directory: /epicfiles/nonprdfiles/event_log/?",
            "    ",
            "    [] Restore non-prd cert paths for ECF/TLS",
            "    d ^%ZeUSTBL",
            "        Communication >> Security >> TLS Settings",
            "        Public certificate file: /epic/local/epic/nonprd/certs/ecf-tls-np.cer",
            "        Private key file: /epic/local/epic/nonprd/certs/private/ecf-tls-np.key",
            "",
            "    [] Reset envcopy and re-enable alerting",
            "    \\$ /epic/bin/envcopy --reset -s ?",
            "    \\$ /epic/redalert/bin/ra_sched --ea",
            "",
            "    [] Change the stage on the current break hook script from `PRERUNTASK` to `PREEXECUTION`",
            "    \\$ /epic/bin/configure",
            "        Environment Copy >> Scenarios >> ? >> Edit Hooks",
            "",
            "[] Move reinit CHG to review and close if no issues"
        ]
    },
    "Downtime SUs": {
        "prefix": "Downtime SUs",
        "description": "",
        "body": [
            "[] Move SU CHG to implement",
            "",
            "[] Move Kuiper upgrade console through the `Mark as Done to Automatically Bring the Environments Down NOW` step  and through the remainder of the deployment",
            "",
            "[] Move SU CHG to review and close if no issues"
        ]
    },
    "Downtime SUs + License Apply": {
        "prefix": "Downtime SUs + License Apply",
        "description": "",
        "body": [
            "[] Move SU CHG to implement",
            "[] Move License apply CHG to implement",
            "",
            "[] Move Kuiper upgrade console through the `Mark as Done to Automatically Bring the Environments Down NOW` step and up to but not through the `Apply the Licenses` step",
            "",
            "    == At the \"Apply the Licenses\" step ==",
            "    As epicadm (\\$) on ?:",
            "        Apply the staged license in [] ?:",
            "            \\$ iris session {env} -U {env}",
            "                d ^%ZeADMIN >> Apply Stage Licenses",
            "    ",
            "[] Move Kuiper upgrade console through the `Apply the Licenses` step and through the remainder of the deployment",
            "[] Move SU CHG to review and close if no issues",
            "[] Move License apply ? to review and close if no issues"
        ]
    },
