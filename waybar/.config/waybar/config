{
  "layer": "top",
  "position": "top",
  "margin-bottom": 0,
  "modules-left": [
    "clock",
    "hyprland/workspaces",
    "custom/updates",
    "tray"
  ],
  "modules-center": [
    "hyprland/window"
  ],
  "modules-right": [
    "network",
    "temperature",
    "cpu",
    "memory",
    "wireplumber",
    "custom/powermenu"
  ],
  "tray": {
    "icon-size": 24,
    "spacing": 10
  },
  "clock": {
    "format": "{:%a %B %d %H:%M}",
    "interval": 60
  },
  "hyprland/workspaces": {
    "format": "{icon}",
    "format-icons": {
      "1": "≤░▓ι",
      "2": "≤░▓λ",
      "3": "≤░▓ν",
      "4": "≤░▓ο",
      "5": "≤░▓ρ",
      "6": "≤░▓ς",
      "7": "≤░▓υ",
      "8": "≤░▓χ",
      "9": "≤░▓░",
      "10": "≤░┐υ",
      "-99": "Όυμ",
      "active": "ΎΕΣ",
      "default": "ΎΕΝ"
    }
  },
  "custom/updates": {
    "format": "<span color=\"#61afef\">ΎΓς</span> {}",
    "tooltip": false,
    "interval": 3600,
    "exec": "exec $HOME/.config/waybar/checkupdate.sh"
  },
  "hyprland/window": {
    "format": " {} ",
    "separate-outputs": false
  },
  "network": {
    "interface": "enp3s0",
    "tooltip-format-ethernet": "{ifname} ΎΔΒ",
    "interval": 2,
    "format": "ΎΔΩ {bandwidthDownBits} ΎΔα {bandwidthUpBits}"
  },
  "temperature": {
    "format": "{icon} {temperatureC}┬░C",
    "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
    "critical-threshold": 80,
    "format-icons": [
      "ΎΜΜ",
      "ΎΜΚ",
      "ΎΜΘ"
    ]
  },
  "cpu": {
    "format": "ΎΜδ {}%",
    "tooltip": "false"
  },
  "memory": {
    "format": "ΎΦ╕ {}%",
    "tooltip": "false"
  },
  "wireplumber": {
    "format": "{icon} {volume}%",
    "format-muted": "Ύγσ {volume}%",
    "on-click": "helvum",
    "format-icons": [
      "ΎΑο",
      "ΎΑπ",
      "ΎΑρ"
    ]
  },
  "custom/powermenu": {
    "format": "ΎΑΣ",
    "tooltip": false,
    "on-click": "exec wlogout -p layer-shell"
  }
}